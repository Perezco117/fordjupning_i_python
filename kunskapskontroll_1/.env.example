# === OMDb API inställningar ===
# Lägg in din egen API-nyckel från http://www.omdbapi.com/
OMDB_API_KEY=DIN_API_NYCKEL_HÄR

# Söksträng för filmer (kan ändras)
SEARCH_QUERY=Batman

# === SQLite inställningar ===
# Standard: SQLite-fil i ./data/
DATABASE_URL=sqlite:///./data/etl.db

# === Loggning ===
# Loggmapp och loggfil
LOG_DIR=./logs
LOG_FILE=app.log
